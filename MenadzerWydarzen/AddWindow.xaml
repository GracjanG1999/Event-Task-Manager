<Window x:Class="MenadzerWydarzen.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nowe Wydarzenie"
        Height="560" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Style="{StaticResource Card}" Margin="14">
        <DockPanel>

            <!-- Przyciski zawsze na dole -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Anuluj" Style="{StaticResource OutlineButton}"
                        Click="CancelButton_Click" Width="90" Margin="0,0,10,0"/>
                <Button Content="+ Dodaj" Click="AddBtn_Click" Width="110"/>
            </StackPanel>

            <!-- Formularz przewijany -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Nagłówek -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="+" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Nowe Wydarzenie"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Nazwa -->
                    <TextBlock Text="Nazwa" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameInput" Margin="0,0,0,12"/>

                    <!-- Data + czasy -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="108"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="108"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Data" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <DatePicker x:Name="DatePickerCtrl"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Start (HH:mm)" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="StartTimeInput"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Koniec (HH:mm)" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="EndTimeInput"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status + Priorytet -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Status" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="StatusCombo">
                                <ComboBoxItem Content="Oczekujące" IsSelected="True"/>
                                <ComboBoxItem Content="Trwa"/>
                                <ComboBoxItem Content="Zrealizowane"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Priorytet" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="PriorityCombo">
                                <ComboBoxItem Content="Niski"/>
                                <ComboBoxItem Content="Średni" IsSelected="True"/>
                                <ComboBoxItem Content="Wysoki"/>
                                <ComboBoxItem Content="Krytyczny"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Kategoria -->
                    <TextBlock Text="Kategoria" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="CategoryInput" Margin="0,0,0,12"/>

                    <!-- Opis -->
                    <TextBlock Text="Opis / Notatki" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="DescriptionInput" Height="70"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
