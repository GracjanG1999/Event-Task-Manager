<Window x:Class="MenadzerWydarzen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MenadzerWydarzen"
        Title="Menadżer Wydarzeń" Height="700" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:StatusConverter x:Key="StatusConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Lista Zadań" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <GroupBox Header="Dodaj nowe wydarzenie" Margin="0,0,0,10" Padding="10">
                <StackPanel>
                    <TextBlock Text="Nazwa:"/>
                    <TextBox x:Name="NameInput" Margin="0,5"/>
                    <TextBlock Text="Data planowana:"/>
                    <DatePicker x:Name="PlannedDatePicker" Margin="0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Width="150">
                            <TextBlock Text="Godzina startu (HH:mm):"/>
                            <TextBox x:Name="StartTimeInput" Margin="0,5"/>
                        </StackPanel>
                        <StackPanel Width="150" Margin="10,0,0,0">
                            <TextBlock Text="Godzina końca (HH:mm):"/>
                            <TextBox x:Name="EndTimeInput" Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Status:"/>
                    <ComboBox x:Name="StatusCombo" Margin="0,5">
                        <ComboBoxItem Content="Oczekujące" IsSelected="True"/>
                        <ComboBoxItem Content="Trwa"/>
                        <ComboBoxItem Content="Zrealizowane"/>
                    </ComboBox>
                    <Button Content="Dodaj Wydarzenie" Click="AddButton_Click" Margin="0,10,0,0" Background="LightBlue"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Content="Zmień Status" Click="EditButton_Click" Width="100" Margin="5,0" Background="LightGreen"/>
            <Button Content="Usuń" Click="DeleteButton_Click" Width="80" Background="LightCoral"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="EventsGrid" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" />
                <DataGridTextColumn Header="Data" Binding="{Binding PlannedDate, StringFormat=\{0:yyyy-MM-dd\}}" />
                <DataGridTextColumn Header="Start" Binding="{Binding StartTime, StringFormat=\{0:hh\\:mm\}}" />
                <DataGridTextColumn Header="Koniec" Binding="{Binding EndTime, StringFormat=\{0:hh\\:mm\}}" />
               <DataGridTextColumn Header="Status" Binding="{Binding Status, Converter={StaticResource StatusConverter}}" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
              <TextBlock x:Name="TxtStatusSummary" Text="Statystyki: Ładowanie..." FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>